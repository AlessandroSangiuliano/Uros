	cd /home/slex/Scrivania/osfmk-mklinux/osfmk/build && $(MAKE) $(MAKESILENT) -f src/mach_services/lib/migcom/CMakeFiles/migcom.dir/build.make src/mach_services/lib/migcom/CMakeFiles/migcom.dir/utils.c.i
.PHONY : utils.c.i

utils.s: utils.c.s
.PHONY : utils.s

# target to generate assembly for a file
utils.c.s:
	cd /home/slex/Scrivania/osfmk-mklinux/osfmk/build && $(MAKE) $(MAKESILENT) -f src/mach_services/lib/migcom/CMakeFiles/migcom.dir/build.make src/mach_services/lib/migcom/CMakeFiles/migcom.dir/utils.c.s
.PHONY : utils.c.s

